{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/git-push-gate.sh"}],
        "description": "Review gate before git push"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/doc-file-warning.sh"}],
        "description": "Warn about writing binary document files"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/console-log-check.sh", "async": true, "timeout": 10}],
        "description": "Check for console.log statements after edits (async)"
      },
      {
        "matcher": "Edit",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/eslint-check.sh", "async": true, "timeout": 15}],
        "description": "Run ESLint on edited files (async)"
      }
    ]
  }
}